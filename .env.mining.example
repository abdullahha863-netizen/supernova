# Mining gateway
MINING_WS_HOST=0.0.0.0
MINING_WS_PORT=8081
MINING_WS_PATH=/ws/mining
MINING_WS_CLUSTER=true
MINING_WS_WORKERS=4
MINING_RATE_LIMIT_PER_SECOND=12000

# Queue
RABBITMQ_URL=amqp://guest:guest@localhost:5672
MINING_SHARE_QUEUE=mining.share.submit.v1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# App auth
JWT_SECRET=change-me

# Worker tuning
MINING_BATCH_SIZE=300
MINING_BATCH_FLUSH_MS=1000
MINING_QUEUE_PREFETCH=800

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/supernova?schema=public

# Real Kaspa RPC configuration required for production mining services
KASPA_RPC_URL=https://replace-with-kaspa-rpc.example
KASPA_RPC_USERNAME=
KASPA_RPC_PASSWORD=
KASPA_NETWORK=mainnet
KASPA_POOL_ADDRESS=kaspa:replace_with_pool_address
