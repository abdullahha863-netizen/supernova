# Core app runtime settings used across the web app and supporting services.
NODE_ENV="production"
NEXT_PUBLIC_URL="https://your-domain.example"
BASE_URL="https://your-domain.example"
NEXT_PUBLIC_APP_NAME="Supernova"
SUPERNOVA_BACKEND_URL="https://your-domain.example"
LOG_LEVEL="info"

# Primary relational database connection for the app and mining data access.
DATABASE_URL="postgresql://your_db_user:your_db_password@your_db_host:5432/your_db_name?schema=public"

# Authentication, session signing, admin access, and development-only dashboard fallback.
JWT_SECRET="your_jwt_secret_here"
ADMIN_KEY="your_admin_key_here"
CHECKOUT_INTENT_SIGNING_KEY="your_checkout_intent_signing_key_here"
DEV_DASHBOARD_USER_ID="your_dev_dashboard_user_id_here"

# SMTP email delivery for password reset, verification, 2FA email codes, and security notifications.
EMAIL_TRANSPORT="smtp"
EMAIL_FROM="no-reply@your-domain.example"
SMTP_HOST="smtp.your-provider.example"
SMTP_PORT="587"
SMTP_USER="your_smtp_username_here"
SMTP_PASS="your_smtp_password_here"

# Stripe card checkout configuration. Enable only when keys and webhook are set.
ENABLE_STRIPE_CHECKOUT="true"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_your_value_here"
STRIPE_SECRET_KEY="sk_live_your_value_here"
STRIPE_WEBHOOK_SECRET="whsec_your_value_here"

# NOWPayments crypto checkout configuration. Enable only when API and IPN secrets are set.
ENABLE_NOWPAYMENTS_CHECKOUT="false"
NOWPAYMENTS_API_KEY="your_nowpayments_api_key_here"
NOWPAYMENTS_IPN_SECRET="your_nowpayments_ipn_secret_here"

# Redis supports mining rate limiting, PoW coordination, and runtime shared state.
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="your_redis_password_here"

# RabbitMQ powers share submission and mining queue workflows.
RABBITMQ_URL="amqp://your_rabbitmq_user:your_rabbitmq_password@your_rabbitmq_host:5672"
MINING_SHARE_QUEUE="mining.share.submit.v1"

# Real Kaspa RPC configuration required for production mining services.
KASPA_RPC_URL="https://your-kaspa-rpc.example"
KASPA_RPC_USERNAME=""
KASPA_RPC_PASSWORD=""
KASPA_NETWORK="mainnet"
KASPA_POOL_ADDRESS="kaspa:your_pool_address_here"

# Mining WebSocket gateway configuration for realtime miner traffic.
MINING_WS_HOST="0.0.0.0"
MINING_WS_PORT="8081"
MINING_WS_PATH="/ws/mining"
MINING_WS_CLUSTER="true"
MINING_WS_WORKERS="4"
MINING_RATE_LIMIT_PER_SECOND="12000"

# Stratum gateway configuration for mining protocol access and job distribution.
STRATUM_HOST="0.0.0.0"
STRATUM_V1_PORT="3333"
STRATUM_V2_PORT="3334"
STRATUM_DEFAULT_DIFFICULTY="1024"
STRATUM_RATE_LIMIT_PER_SECOND="5000"
STRATUM_JOB_INTERVAL_MS="15000"
STRATUM_JOB_TTL_MS="45000"
STRATUM_CLUSTER="true"
STRATUM_WORKERS="4"
STRATUM_AUTH_TIMEOUT_MS="10000"
STRATUM_V2_VERSION_ROLLING_MASK="1fffe000"

# Pool endpoints exposed to the frontend for connection guides and worker setup instructions.
NEXT_PUBLIC_POOL_STRATUM_HOST="snovapool.io"
NEXT_PUBLIC_POOL_STRATUM_PORT="3333"
NEXT_PUBLIC_POOL_REST_HOST="snovapool.io"
NEXT_PUBLIC_POOL_REST_PORT="443"
NEXT_PUBLIC_POOL_NAME="SUPERNOVA"
NEXT_PUBLIC_POOL_FEE="2"

# Mining workers and background processing tune batching, snapshots, and retention.
MINING_BATCH_SIZE="300"
MINING_BATCH_FLUSH_MS="1000"
MINING_QUEUE_PREFETCH="800"
MINING_HASHRATE_SNAPSHOT_INTERVAL_MS="300000"
MINING_HASHRATE_HISTORY_RETENTION_DAYS="30"

# Feature flags for admin observability and mining runtime endpoints.
ENABLE_ADMIN_MINING_STATS="true"
ENABLE_MINING_RUNTIME_METRICS="true"
NEXT_PUBLIC_ENABLE_MINING_RUNTIME_METRICS="true"
ENABLE_HASHRATE_WRITER_STATUS="true"

# Optional load-test and integration-test values for local verification tools.
MINING_LOAD_DURATION_SEC="60"
MINING_LOAD_CONNECTIONS="25"
MINING_LOAD_RATE="100"
MINING_TOKEN="your_mining_test_token_here"
MINING_REST_URL="http://localhost:3000/api/mining/submit-share"
MINING_WS_URL="ws://localhost:8081/ws/mining"
MINING_HEALTH_URL="http://localhost:3000/api/mining/health"
MINING_STRATUM_HOST="127.0.0.1"
MINING_STRATUM_PORT="3333"
MINING_MINER_IDS="miner-1,miner-2"
MINING_WORKER_NAMES="worker-a,worker-b"

# Optional helper used by local verification scripts to point at a specific env file.
ENV_FILE=".env"
