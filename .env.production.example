NODE_ENV="production"
NEXT_PUBLIC_APP_NAME="Supernova"
NEXT_PUBLIC_URL="https://your-production-domain.example"
BASE_URL="https://your-production-domain.example"
SUPERNOVA_BACKEND_URL="https://your-production-domain.example"

DATABASE_URL="postgresql://replace_with_user:replace_with_password@replace_with_host:5432/replace_with_database?schema=public"

JWT_SECRET="replace-with-a-long-random-jwt-secret"
ADMIN_KEY="replace-with-a-long-random-admin-key"
CHECKOUT_INTENT_SIGNING_KEY="replace-with-a-long-random-checkout-signing-key"

EMAIL_TRANSPORT="smtp"
SMTP_HOST="smtp.your-provider.example"
SMTP_PORT="587"
SMTP_USER="replace-with-smtp-user"
SMTP_PASS="replace-with-smtp-password"
SMTP_FROM="no-reply@your-production-domain.example"
EMAIL_FROM="no-reply@your-production-domain.example"

ENABLE_STRIPE_CHECKOUT="false"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_replace_me"
STRIPE_SECRET_KEY="sk_live_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"

ENABLE_NOWPAYMENTS_CHECKOUT="false"
NOWPAYMENTS_API_KEY="replace_me_if_enabled"
NOWPAYMENTS_IPN_SECRET="replace_me_if_enabled"

REDIS_HOST="replace-with-redis-host"
REDIS_PORT="6379"
REDIS_PASSWORD=""

RABBITMQ_URL="amqp://replace_with_user:replace_with_password@replace_with_rabbitmq_host:5672"
MINING_SHARE_QUEUE="mining.share.submit.v1"

KASPA_RPC_URL="https://replace-with-kaspa-rpc.example"
KASPA_RPC_USERNAME=""
KASPA_RPC_PASSWORD=""
KASPA_NETWORK="mainnet"
KASPA_POOL_ADDRESS="kaspa:replace_with_pool_address"

MINING_WS_HOST="0.0.0.0"
MINING_WS_PORT="8081"
MINING_WS_PATH="/ws/mining"
MINING_WS_CLUSTER="true"
MINING_WS_WORKERS="4"

STRATUM_HOST="0.0.0.0"
STRATUM_V1_PORT="3333"
STRATUM_V2_PORT="3334"
STRATUM_CLUSTER="true"
STRATUM_WORKERS="4"
